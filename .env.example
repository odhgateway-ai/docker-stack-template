# ================================================================
#  .env.example — Docker Stack Template
#  Copy to .env and fill in your values:
#    cp .env.example .env
#
#  Then run validation before deploying:
#    npm run validate
# ================================================================

# ================================================================
#  CORE — Required for every deployment
# ================================================================

# Stack identifier: used as Docker network name + Tailscale hostname
# Keep it short, alphanumeric + hyphens (e.g. myapp, gitea-prod)
STACK_NAME=mystack

# Project name: drives auto-generated subdomains
#   app   → ${PROJECT_NAME}.${DOMAIN}
#   logs  → logs.${PROJECT_NAME}.${DOMAIN}
#   files → files.${PROJECT_NAME}.${DOMAIN}
#   ssh   → ttyd.${PROJECT_NAME}.${DOMAIN}
PROJECT_NAME=myapp

# Root domain — no http://, no trailing slash
DOMAIN=example.com

# Email for Caddy SSL via Let's Encrypt
CADDY_EMAIL=admin@example.com

# ================================================================
#  CADDY AUTH — Basic Auth protects all routes by default
# ================================================================
CADDY_AUTH_USER=admin

# Generate bcrypt hash:
#   docker run --rm caddy:alpine caddy hash-password --plaintext "YourPassword"
# Store it in .env exactly as generated, wrapped in single quotes.
CADDY_AUTH_HASH='$2a$14$replacethiswithyourrealhashvalue00000000000000000000'

# ================================================================
#  APPLICATION — Change these per deployment
# ================================================================

# Port the app exposes inside the container
APP_PORT=3000

# Localhost port published on the host machine for direct browser access
APP_HOST_PORT=3000

# Internal HTTPS hostname served by Caddy with tls internal.
# Replace this with a name that resolves inside your tailnet, such as a MagicDNS host.
TAILSCALE_HTTPS_HOST=${STACK_NAME}.tailnet.local

# Optional: health check path (default /health)
HEALTH_PATH=/health

# Node.js / generic runtime env
NODE_ENV=production

# ================================================================
#  CLOUDFLARE TUNNEL
# ================================================================

# Tunnel credentials are stored in cloudflared/config.yml
# and cloudflared/credentials.json (never commit credentials!)
#
# For CI/CD via RTDB (optional):
# CLOUDFLARED_TUNNEL_CREDENTIALS_BASE64=<base64-of-credentials.json>

# ================================================================
#  TAILSCALE — Only required if ENABLE_TAILSCALE=true
# ================================================================

# Get from: https://login.tailscale.com/admin/settings/keys
# Use Reusable + Ephemeral for CI runners
TS_AUTHKEY=tskey-auth-xxxxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ACL tags for this node
TS_TAGS=tag:container

# ================================================================
#  FEATURE FLAGS — Enable/disable optional services
# ================================================================
ENABLE_DOZZLE=true
ENABLE_FILEBROWSER=true
ENABLE_WEBSSH=true
ENABLE_TAILSCALE=false

# ================================================================
#  RUNTIME — Auto-set by CI scripts. Do NOT edit manually.
# ================================================================
# CUR_OS=linux
# DOCKER_SOCK=/var/run/docker.sock
# CUR_WHOAMI=runner
# CUR_WORK_DIR=/home/runner/work
