{
  "name": "docker-stack-template",
  "version": "2.0.0",
  "description": "Modular Docker Compose template — drop-in multi-service deployment",
  "private": true,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dockerapp-validate:👇👇👇👇👇": "==dockerapp-validate==",
    "dockerapp-validate:env": "node docker-compose/scripts/validate-env.js && node H:/nodejs-tester/docker-stack-template/.vscode/hide-panel.js",
    "dockerapp-validate:compose": "node docker-compose/scripts/validate-compose.js",
    "dockerapp-validate:ts": "node docker-compose/scripts/validate-ts.js",
    "dockerapp-validate:all": "npm run dockerapp-validate:env && npm run dockerapp-validate:compose && npm run dockerapp-validate:ts",
    "agent-app-swap:sync": "node scripts/sync-agent-app-swap.js & ctrlj",
    "tailscale-remove-hostname": "node tailscale/tailscale-init.js .env --remove-hostname --yes",
    "tailscale-watchdog": "node tailscale/tailscale-watchdog.js",
    "dockerapp-gen:👇👇👇👇👇": "==dockerapp-gen==",
    "dockerapp-gen:caddy-hash": "docker run --rm caddy:alpine caddy hash-password --plaintext",
    "dockerapp-exec:👇👇👇👇👇": "==dockerapp-exec==",
    "dockerapp-exec:up": "bash docker-compose/scripts/dc.sh up -d --build --remove-orphans",
    "dockerapp-exec:up:fresh": "bash docker-compose/scripts/dc.sh down -v && bash docker-compose/scripts/dc.sh up -d --build --remove-orphans",
    "dockerapp-exec:down": "bash docker-compose/scripts/dc.sh down",
    "dockerapp-exec:down:volumes": "bash docker-compose/scripts/dc.sh down -v",
    "dockerapp-exec:restart": "bash docker-compose/scripts/dc.sh restart",
    "dockerapp-exec:restart:app": "bash docker-compose/scripts/dc.sh restart app",
    "dockerapp-exec:pull": "bash docker-compose/scripts/dc.sh pull",
    "dockerapp-exec:ps": "bash docker-compose/scripts/dc.sh ps",
    "dockerapp-exec:logs": "bash docker-compose/scripts/dc.sh logs -f --tail=100",
    "dockerapp-exec:logs:app": "bash docker-compose/scripts/dc.sh logs -f --tail=100 app",
    "dockerapp-exec:logs:caddy": "bash docker-compose/scripts/dc.sh logs -f --tail=100 caddy",
    "dockerapp-exec:logs:cloudflared": "bash docker-compose/scripts/dc.sh logs -f --tail=100 cloudflared",
    "dockerapp-exec:config": "bash docker-compose/scripts/dc.sh config",
    "dockerapp-exec:prune": "docker image prune -f",
    "dockerapp-exec:prune:all": "docker system prune -af --volumes",
    "dockerapp-exec:health": "bash docker-compose/scripts/dc.sh ps && bash docker-compose/scripts/dc.sh logs --tail=20 --no-color",
    "dockerapp-exec:exec:app": "bash docker-compose/scripts/dc.sh exec app sh",
    "dockerapp-exec:exec:caddy": "bash docker-compose/scripts/dc.sh exec caddy sh",
    "git-o": "powershell -NoProfile -Command \"Start-Process -FilePath cmd.exe -WorkingDirectory '%CD%' -ArgumentList '/k', 'git o'\"",
    "git-oexecute": "powershell -NoProfile -Command \"Start-Process -FilePath cmd.exe -WorkingDirectory '%CD%' -ArgumentList '/k', 'git oexecute'\"",
    "git-oaddcommit": "powershell -NoProfile -Command \"Start-Process -FilePath cmd.exe -WorkingDirectory '%CD%' -ArgumentList '/k', 'git oaddcommit'\"",
    "git-oclone": "powershell -NoProfile -Command \"Start-Process -FilePath cmd.exe -WorkingDirectory '%CD%' -ArgumentList '/k', 'git oclone'\"",
    "git-opull": "powershell -NoProfile -Command \"Start-Process -FilePath cmd.exe -WorkingDirectory '%CD%' -ArgumentList '/k', 'git opull'\"",
    "git-opullbranch": "powershell -NoProfile -Command \"Start-Process -FilePath cmd.exe -WorkingDirectory '%CD%' -ArgumentList '/k', 'git opullbranch'\"",
    "git-opush": "powershell -NoProfile -Command \"Start-Process -FilePath cmd.exe -WorkingDirectory '%CD%' -ArgumentList '/k', 'git opush'\"",
    "git-opushforce": "powershell -NoProfile -Command \"Start-Process -FilePath cmd.exe -WorkingDirectory '%CD%' -ArgumentList '/k', 'ctrlj & git opushforce'",
    "git-opushforceurl": "powershell -NoProfile -Command \"Start-Process -FilePath cmd.exe -WorkingDirectory '%CD%' -ArgumentList '/k', 'git opushforceurl'\"",
    "git-opullpush": "powershell -NoProfile -Command \"Start-Process -FilePath cmd.exe -WorkingDirectory '%CD%' -ArgumentList '/k', 'git opullpush'\"",
    "git-ostash": "powershell -NoProfile -Command \"Start-Process -FilePath cmd.exe -WorkingDirectory '%CD%' -ArgumentList '/k', 'git ostash'\"",
    "git-ofetch": "powershell -NoProfile -Command \"Start-Process -FilePath cmd.exe -WorkingDirectory '%CD%' -ArgumentList '/k', 'git ofetch'\"",
    "git-oinit": "powershell -NoProfile -Command \"Start-Process -FilePath cmd.exe -WorkingDirectory '%CD%' -ArgumentList '/k', 'git oinit'\"",
    "git-oconfig": "powershell -NoProfile -Command \"Start-Process -FilePath cmd.exe -WorkingDirectory '%CD%' -ArgumentList '/k', 'git oconfig && exit'\"",
    "git-oconfigclean": "powershell -NoProfile -Command \"Start-Process -FilePath cmd.exe -WorkingDirectory '%CD%' -ArgumentList '/k', 'git oconfigclean'\"",
    "git-ocreateremote": "powershell -NoProfile -Command \"Start-Process -FilePath cmd.exe -WorkingDirectory '%CD%' -ArgumentList '/k', 'git ocreateremote'\"",
    "git-addfile": "powershell -NoProfile -Command \"Start-Process -FilePath cmd.exe -WorkingDirectory '%CD%' -ArgumentList '/k', 'git addfile'\"",
    "git-addfile-packagejson": "powershell -NoProfile -Command \"Start-Process -FilePath cmd.exe -WorkingDirectory '%CD%' -ArgumentList '/k', 'git addfile packagejson'\"",
    "git-addfile-omessage": "powershell -NoProfile -Command \"Start-Process -FilePath cmd.exe -WorkingDirectory '%CD%' -ArgumentList '/k', 'git addfile omessage'\"",
    "git-addfile-ogitignore": "powershell -NoProfile -Command \"Start-Process -FilePath cmd.exe -WorkingDirectory '%CD%' -ArgumentList '/k', 'git addfile ogitignore'\"",
    "env-pull.local": "powershell -NoProfile -Command \"Start-Process -FilePath cmd.exe -WorkingDirectory '%CD%' -ArgumentList '/k', 'dotenvrtdb -e .env -- dotenvrtdb -e .env.local --pull -eUrl=$env:DOTENVRTDB_URL'",
    "stack:clone": "node scripts/clone-stack.js --output H:/nodejs-tester/dockerstack-omniroute --name dockerstack-omniroute --force",
    "stack:clone-dockerstack-s3-proxy": "node scripts/clone-stack.js --output H:/nodejs-tester/dockerstack-s3-proxy --name dockerstack-s3-proxy --force",
    "stack:clone-dockerstack-pocketbase": "node scripts/clone-stack.js --output H:/nodejs-tester/dockerstack-pocketbase --name dockerstack-pocketbase --force",
    "stack:rtdbmanager": "node scripts/clone-stack.js --output H:/nodejs-tester/rtdbmanager --name rtdbmanager --force",
    "stack:rclonemanager-deploy": "node scripts/clone-stack.js --output H:/nodejs-tester/rclonemanager-deploy --name rclonemanager --force",
    "env-cloudflared-create": "ctrlj&powershell -NoProfile -Command \"Start-Process -FilePath cmd.exe -WorkingDirectory '%CD%' -ArgumentList '/k', 'dotenvrtdb -e .env -- ocli cloudflared'\"",
    "tailscale-init": "node tailscale/tailscale-init.js .env",
    "ocli-gh": "ctrlj&powershell -NoProfile -Command \"Start-Process -FilePath cmd.exe -WorkingDirectory '%CD%' -ArgumentList '/k', 'dotenvrtdb -e .env -- ocli gh'\"",
    "env-push": "ctrlj&powershell -NoProfile -Command \"Start-Process -FilePath cmd.exe -WorkingDirectory '%CD%' -ArgumentList '/k', 'dotenvrtdb -e .env --push -eUrl=$env:DOTENVRTDB_URL'\""
  }
}
