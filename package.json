{
  "name": "docker-stack-template",
  "version": "2.0.0",
  "description": "Modular Docker Compose template — drop-in multi-service deployment",
  "private": true,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dockerapp-validate:👇👇👇👇👇": "==dockerapp-validate==",
    "dockerapp-validate:env": "node docker-compose/scripts/validate-env.js && node H:/nodejs-tester/docker-stack-template/.vscode/hide-panel.js",
    "dockerapp-validate:compose": "node docker-compose/scripts/validate-compose.js",
    "dockerapp-validate:ts": "node docker-compose/scripts/validate-ts.js",
    "dockerapp-validate:all": "npm run dockerapp-validate:env && npm run dockerapp-validate:compose && npm run dockerapp-validate:ts",
    "agent-app-swap:sync": "node scripts/sync-agent-app-swap.js & ctrlj",
    "tailscale-remove-hostname": "node tailscale/tailscale-init.js .env --remove-hostname --yes",
    "tailscale-watchdog": "node tailscale/tailscale-watchdog.js",
    "dockerapp-gen:👇👇👇👇👇": "==dockerapp-gen==",
    "dockerapp-gen:caddy-hash": "docker run --rm caddy:alpine caddy hash-password --plaintext",
    "dockerapp-exec:👇👇👇👇👇": "==dockerapp-exec==",
    "dockerapp-exec:up": "bash docker-compose/scripts/dc.sh up -d --build --remove-orphans",
    "dockerapp-exec:up:fresh": "bash docker-compose/scripts/dc.sh down -v && bash docker-compose/scripts/dc.sh up -d --build --remove-orphans",
    "dockerapp-exec:down": "bash docker-compose/scripts/dc.sh down",
    "dockerapp-exec:down:volumes": "bash docker-compose/scripts/dc.sh down -v",
    "dockerapp-exec:restart": "bash docker-compose/scripts/dc.sh restart",
    "dockerapp-exec:restart:app": "bash docker-compose/scripts/dc.sh restart app",
    "dockerapp-exec:pull": "bash docker-compose/scripts/dc.sh pull",
    "dockerapp-exec:ps": "bash docker-compose/scripts/dc.sh ps",
    "dockerapp-exec:logs": "bash docker-compose/scripts/dc.sh logs -f --tail=100",
    "dockerapp-exec:logs:app": "bash docker-compose/scripts/dc.sh logs -f --tail=100 app",
    "dockerapp-exec:logs:caddy": "bash docker-compose/scripts/dc.sh logs -f --tail=100 caddy",
    "dockerapp-exec:logs:cloudflared": "bash docker-compose/scripts/dc.sh logs -f --tail=100 cloudflared",
    "dockerapp-exec:logs:deploy-code": "bash docker-compose/scripts/dc.sh logs -f --tail=100 deploy-code",
    "dockerapp-exec:config": "bash docker-compose/scripts/dc.sh config",
    "dockerapp-exec:prune": "docker image prune -f",
    "dockerapp-exec:prune:all": "docker system prune -af --volumes",
    "dockerapp-exec:health": "bash docker-compose/scripts/dc.sh ps && bash docker-compose/scripts/dc.sh logs --tail=20 --no-color",
    "dockerapp-exec:exec:app": "bash docker-compose/scripts/dc.sh exec app sh",
    "dockerapp-exec:exec:caddy": "bash docker-compose/scripts/dc.sh exec caddy sh",
    "dockerapp-exec:exec:deploy-code": "bash docker-compose/scripts/dc.sh exec deploy-code sh",
    "git-o": "git o",
    "git-oexecute": "git oexecute",
    "git-oaddcommit": "git oaddcommit",
    "git-oclone": "git oclone",
    "git-opull": "git opull",
    "git-opullbranch": "git opullbranch",
    "git-opush": "git opush",
    "git-opushforce": "git opushforce",
    "git-opushforceurl": "git opushforceurl",
    "git-opullpush": "git opullpush",
    "git-ostash": "git ostash",
    "git-ofetch": "git ofetch",
    "git-oinit": "git oinit",
    "git-oconfig": "git oconfig && exit",
    "git-oconfigclean": "git oconfigclean",
    "git-ocreateremote": "git ocreateremote",
    "git-addfile": "git addfile",
    "git-addfile-packagejson": "git addfile packagejson",
    "git-addfile-omessage": "git addfile omessage",
    "git-addfile-ogitignore": "git addfile ogitignore",
    "env-pull.local": "dotenvrtdb -e .env -- dotenvrtdb -e .env.local --pull -eUrl=$env:DOTENVRTDB_URL",
    "stack:clone": "node scripts/clone-stack.js --output H:/nodejs-tester/dockerstack-omniroute --name dockerstack-omniroute --force",
    "stack:clone-dockerstack-s3-proxy": "node scripts/clone-stack.js --output H:/nodejs-tester/dockerstack-s3-proxy --name dockerstack-s3-proxy --force",
    "stack:clone-dockerstack-pocketbase": "node scripts/clone-stack.js --output H:/nodejs-tester/dockerstack-pocketbase --name dockerstack-pocketbase --force",
    "stack:rtdbmanager": "node scripts/clone-stack.js --output H:/nodejs-tester/rtdbmanager --name rtdbmanager --force",
    "stack:rclonemanager-deploy": "node scripts/clone-stack.js --output H:/nodejs-tester/rclonemanager-deploy --name rclonemanager --force",
    "stack:rclonemanager-collabmd": "node scripts/clone-stack.js --output H:/nodejs-tester/rclonemanager-collabmd --name rclonemanagercollabmd --force",
    "stack:dockerstackds2api": "node scripts/clone-stack.js --output H:/nodejs-tester/dockerstackds2api --name dockerstackds2api --force",
    "env-cloudflared-create": "dotenvrtdb -e .env -- ocli cloudflared",
    "tailscale-init": "node tailscale/tailscale-init.js .env",
    "ocli-gh": "dotenvrtdb -e .env -- ocli gh",
    "env-push": "dotenvrtdb -e .env --push -eUrl=$env:DOTENVRTDB_URL"
  }
}
