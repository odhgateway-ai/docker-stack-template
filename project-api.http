# VS Code REST Client requests for this project
# Extension: REST Client (humao.rest-client)
#
# This file reads values from the local .env via {{$dotenv VAR_NAME}}.
# If you need a Basic Auth token for Caddy / public domain requests:
# PowerShell:
# [Convert]::ToBase64String([Text.Encoding]::ASCII.GetBytes("admin:YOUR_PASSWORD"))

@project_name = {{$dotenv PROJECT_NAME}}
@domain = {{$dotenv DOMAIN}}
@stack_name = {{$dotenv STACK_NAME}}
@app_port = {{$dotenv APP_PORT}}
@app_host_port = {{$dotenv APP_HOST_PORT}}
@health_path = {{$dotenv HEALTH_PATH}}
@caddy_auth_user = {{$dotenv CADDY_AUTH_USER}}
@tailscale_https_host = {{$dotenv TAILSCALE_HTTPS_HOST}}
@tailscale_tailnet_domain = {{$dotenv TAILSCALE_TAILNET_DOMAIN}}

@app_local = http://localhost:{{app_host_port}}
@caddy_local = http://localhost
@host_main = main.{{domain}}
@host_project = {{project_name}}.{{domain}}
@public_main = https://{{host_main}}
@public_project = https://{{host_project}}
@tailscale_https = https://{{tailscale_https_host}}
@tailscale_magicdns_host = {{stack_name}}.{{tailscale_tailnet_domain}}
@tailscale_magicdns_https = https://{{tailscale_magicdns_host}}
@basic_auth = YWRtaW46QWRtaW5AMTIzQWRtaW5AMTIz

###
# Direct app access on the published local port
GET {{app_local}}/
Accept: application/json

###
GET {{app_local}}{{health_path}}
Accept: application/json

###
GET {{app_local}}/logs/tail
Accept: application/json

###
GET {{caddy_local}}/
Host: {{host_main}}
Accept: application/json
Authorization: Basic {{basic_auth}}

###
GET {{caddy_local}}{{health_path}}
Host: {{host_main}}
Accept: application/json
Authorization: Basic {{basic_auth}}

###
# Through local Caddy using the project hostname alias
GET {{caddy_local}}/
Host: {{host_project}}
Accept: application/json
Authorization: Basic {{basic_auth}}

###
# Public domain through Cloudflare Tunnel
GET {{public_main}}/
Accept: application/json
Authorization: Basic {{basic_auth}}

###
GET {{public_main}}{{health_path}}
Accept: application/json
Authorization: Basic {{basic_auth}}

###
# Public project hostname alias
GET {{public_project}}/
Accept: application/json
Authorization: Basic {{basic_auth}}

###
# Tailscale HTTPS via MagicDNS (*.ts.net) served by TS_SERVE_CONFIG.
# Expected:
# - 401 when Basic Auth header is missing/invalid
# - 200 when Basic Auth header is correct
GET {{tailscale_magicdns_https}}/
Accept: application/json
Authorization: Basic {{basic_auth}}

###
GET {{tailscale_magicdns_https}}{{health_path}}
Accept: application/json
Authorization: Basic {{basic_auth}}
